{
  "manifest_version": 3,
  "name": "CYBER PINGER",
  "version": "1.0.0",
  "author": "K NIRMAL",
  "organization": "Cyber Yakku TM",
  "description": "A powerful network pinger tool for PC by K NIRMAL | Cyber Yakku TM.",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "Icons/icon128.png",
      "48": "Icons/icon48.png",
      "16": "Icons/icon16.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "Icons/icon128.png",
    "48": "Icons/icon48.png",
    "16": "Icons/icon16.png"
  }
}